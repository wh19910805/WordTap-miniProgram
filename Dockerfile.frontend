FROM node:18-alpine as build

# 设置工作目录
WORKDIR /app

# 复制前端依赖文件
COPY package*.json ./

# 安装依赖
RUN npm install

# 复制前端代码
COPY . .

# 构建前端
RUN npm run build

FROM nginx:alpine

# 复制构建好的前端文件
COPY --from=build /app/dist /usr/share/nginx/html

# 复制Nginx配置文件
COPY nginx.conf /etc/nginx/conf.d/default.conf

# 暴露端口
EXPOSE 80
EXPOSE 443

# 运行Nginx
CMD ["nginx", "-g", "daemon off;"]